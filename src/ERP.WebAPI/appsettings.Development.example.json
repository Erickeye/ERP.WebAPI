{
  "ConnectionStrings": {
    "ERP": "Server=localhost;Database=ERP;User Id=<user>;Password=<password>;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Issuer": "ERP.AuthService",
    "Audience": "ERP.API",
    "SecretKey": "<jwt-secret-key>",
    "AccessTokenExpirationMinutes": 420,
    "RefreshTokenExpirationDays": 10
  },
  "RedisSettings": {
    "ConnectionString": "127.0.0.1:6379",
    "Password": "<redis-password>"
  },
  "SftpConfig": {
    "Host": "127.0.0.1",
    "Port": 22,
    "Username": "<sftp-user>",
    "Password": "<sftp-password>",
    "RemotePath": "/"
  }
}
